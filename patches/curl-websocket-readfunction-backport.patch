+static CURLcode pingpong(CURL *curl, const char *payload)
+{
+  CURLcode result;
+  int i;
+
+  result = ws_send_ping(curl, payload);
+  if(result)
+    return result;
+  for(i = 0; i < 10; ++i) {
+    curl_mfprintf(stderr, "Receive pong\n");
+    result = ws_recv_pong(curl, payload);
+    if(result == CURLE_AGAIN) {
+      curlx_wait_ms(100);
+      continue;
+    }
+    ws_close(curl);
+    return result;
+  }
+  ws_close(curl);
+  return CURLE_RECV_ERROR;
+}
